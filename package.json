{
  "name": "ux-audit-cli",
  "version": "0.0.0",
  "description": "Automated UX audit CLI — Playwright + axe-core, driven by your existing coding CLI (Claude Code, Codex, Gemini CLI)",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "bin": {
    "ux-audit": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@clack/prompts": "^1.7.0",
    "@playwright/mcp": "^0.0.78",
    "commander": "^15.0.0",
    "playwright": "^1.61.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.111.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
